{
    "name": "galleo",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.33.2",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "git config core.hooksPath .githooks || true",
        "dev": "vite",
        "build": "vite build",
        "start": "NODE_ENV=production tsx services/server.ts",
        "preview": "vite preview",
        "preapi": "bash scripts/ensure-db.sh",
        "api": "tsx watch services/server.ts",
        "api:watch": "tsx watch services/server.ts",
        "seed": "tsx services/seed.ts",
        "ai:eval": "tsx services/ai/eval/harness.ts",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^4.0.8",
        "@ai-sdk/google": "^4.0.8",
        "@ai-sdk/openai": "^4.0.8",
        "@ai-sdk/xai": "^4.0.6",
        "@dagrejs/dagre": "^3.0.0",
        "@hono/node-server": "^2.0.6",
        "@solidjs/router": "^0.16.1",
        "ai": "^7.0.15",
        "d3-hierarchy": "^3.1.2",
        "d3-scale": "^4.0.2",
        "d3-shape": "^3.2.0",
        "dompurify": "^3.4.11",
        "drizzle-kit": "^0.30.1",
        "drizzle-orm": "^0.38.0",
        "hono": "^4.12.27",
        "jszip": "^3.10.1",
        "marked": "^18.0.6",
        "pdf-lib": "^1.17.1",
        "postgres": "^3.4.5",
        "pptxgenjs": "^4.0.1",
        "solid-js": "^1.9.13",
        "stripe": "^22.3.0",
        "tsx": "^4.22.4",
        "wawoff2": "^2.0.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/d3-scale": "^4.0.9",
        "@types/d3-shape": "^3.1.8",
        "@types/node": "^22.10.5",
        "@vitest/coverage-v8": "^4.1.10",
        "dotenv": "^17.4.2",
        "eslint": "^9.18.0",
        "eslint-plugin-import": "^2.31.0",
        "happy-dom": "^20.10.6",
        "prettier": "^3.4.2",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.19.1",
        "vite": "^8.1.0",
        "vite-plugin-solid": "^2.11.12",
        "vitest": "^4.1.10"
    }
}
