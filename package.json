{
    "name": "galleo",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.33.2",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "git config core.hooksPath .githooks || true",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "preapi": "bash scripts/ensure-db.sh",
        "api": "tsx services/server.ts",
        "api:watch": "tsx watch services/server.ts",
        "seed": "tsx services/seed.ts",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.6",
        "@solidjs/router": "^0.16.1",
        "drizzle-orm": "^0.38.0",
        "hono": "^4.12.27",
        "pdf-lib": "^1.17.1",
        "postgres": "^3.4.5",
        "solid-js": "^1.9.13",
        "stripe": "^22.3.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^22.10.5",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.30.1",
        "eslint": "^9.18.0",
        "eslint-plugin-import": "^2.31.0",
        "prettier": "^3.4.2",
        "tailwindcss": "^4.3.1",
        "tsx": "^4.22.4",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.19.1",
        "vite": "^8.1.0",
        "vite-plugin-solid": "^2.11.12"
    }
}
