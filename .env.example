# Copy to .env for local dev. Postgres host port is 8602 (see .docs/architecture.md).
DATABASE_URL=postgres://galleo:galleo@localhost:8602/galleo
SESSION_SECRET=dev-secret-change-me
API_PORT=8601

# --- OAuth sign-in (Google / Microsoft) ---
# Routes report "not configured" until a provider's id + secret are set (the auth page hides the button).
# Register the redirect URI EXACTLY as ${APP_URL}/api/auth/<provider>/callback — for local dev that is
#   Google:    http://localhost:8600/api/auth/google/callback
#   Microsoft: http://localhost:8600/api/auth/microsoft/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_TENANT=common

# --- Transactional email (Resend) — email verification, password reset + share invites ---
# Blank = dev mode: verification/reset links are written to the API server log instead of emailed, so
# the flows stay testable without a provider. Get a key at resend.com; MAIL_FROM needs a verified
# domain in production (the resend.dev sender only delivers to your own address while testing).
RESEND_API_KEY=
MAIL_FROM=Galleo <onboarding@resend.dev>

# --- Auth rate limiting ---
# The per-IP limiter derives the client IP from this header (Cloudflare/Render set cf-connecting-ip and
# strip client-sent copies, so it's unspoofable). Change it only behind a different trusted proxy; unset
# falls back to the socket peer. Never trust raw X-Forwarded-For here.
CLIENT_IP_HEADER=cf-connecting-ip

# Required for AI generation (services/agent). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# LLM providers (multi-model). ANTHROPIC + OPENAI already above; add these for Gemini / Grok / Cohere:
GOOGLE_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=

# --- Media picker (services/api/media) ---
# Stock search reports each provider "not configured" until its key is set; the picker's Generate mode
# uses GOOGLE_API_KEY (above). Register a free app with each provider to get a key.
UNSPLASH_ACCESS_KEY=   # unsplash.com/developers  (also requires visible attribution)
PEXELS_API_KEY=        # pexels.com/api
PIXABAY_API_KEY=       # pixabay.com/api/docs
# Optional: override the Gemini image model if Google moves it (default gemini-2.5-flash-image).
GEMINI_IMAGE_MODEL=

# --- Stripe billing (use TEST-mode keys for QA) ---
# Billing routes report "not configured" until STRIPE_SECRET_KEY + both price ids are set.
# 1. Create the account + "Pro" and "Premium" recurring products, each with a monthly AND an annual
#    per-seat price. 2. Paste the four price ids below. 3. Run `stripe listen --forward-to
#    localhost:8601/billing/webhook` and paste the printed whsec_ into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTH=price_...
STRIPE_PRICE_PRO_YEAR=price_...
STRIPE_PRICE_PREMIUM_MONTH=price_...
STRIPE_PRICE_PREMIUM_YEAR=price_...
# Customer Portal configuration id (plan-switching + cancel flow). Create it once via the API
# (billing_portal.configurations) — optional; without it the portal uses the account's default config.
STRIPE_PORTAL_CONFIG=bpc_...
# Where Stripe returns the user after Checkout / the portal (the SPA origin).
APP_URL=http://localhost:8600
